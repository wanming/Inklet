# Copy this file to .env.local for local-only signing and App Store release.
# .env.local is ignored by Git.
INKLET_SIGN_IDENTITY="Apple Distribution: Your Name (<YOUR_TEAM_ID>)"

# Mac App Store release package.
INKLET_APP_STORE_APP_SIGN_IDENTITY="3rd Party Mac Developer Application: Your Name (<YOUR_TEAM_ID>)"
INKLET_APP_STORE_INSTALLER_SIGN_IDENTITY="3rd Party Mac Developer Installer: Your Name (<YOUR_TEAM_ID>)"
INKLET_APP_STORE_PROFILE="$HOME/Downloads/Inklet_Mac_App_Store.provisionprofile"

# App Store Connect API upload credentials.
# Use an app-specific password, not your Apple Account login password.
ASC_EMAIL="you@example.com"
ASC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
